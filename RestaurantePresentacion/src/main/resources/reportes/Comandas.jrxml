                <textElement verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Fecha y Hora]]></text>
            </staticText>
            <staticText>
                <reportElement x="215" y="0" width="105" height="20" forecolor="#FFFFFF" uuid="f12356f1-0123-4402-8616-646e7f167571"/>
                <textElement verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Cliente]]></text>
            </staticText>
            <staticText>
                <reportElement x="325" y="0" width="50" height="20" forecolor="#FFFFFF" uuid="012356f1-1123-4402-8616-646e7f167571"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Mesa]]></text>
