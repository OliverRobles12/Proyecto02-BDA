                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{numeroMesa}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="375" y="0" width="80" height="20" uuid="712356f1-8123-4402-8616-646e7f167571"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{estado}]]></textFieldExpression>
            </textField>

            <textField pattern="$ #,##0.00">
                <reportElement x="455" y="0" width="95" height="20" uuid="812356f1-9123-4402-8616-646e7f167571"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{total}]]></textFieldExpression>
            </textField>
            
            <line>
                <reportElement x="0" y="22" width="555" height="1" forecolor="#E0E0E0" uuid="912356f1-0123-4402-8616-646e7f167571"/>
